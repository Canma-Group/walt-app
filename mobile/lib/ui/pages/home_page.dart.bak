import 'package:banking_app/blocs/auth/auth_bloc.dart';
import 'package:banking_app/config/env.dart';
import 'package:banking_app/services/blockchain_service.dart';
import 'package:flutter/material.dart';
import 'package:flutter_bloc/flutter_bloc.dart';
import 'package:flutter_svg/flutter_svg.dart';
import 'package:google_fonts/google_fonts.dart';
import 'scan_qris_page.dart';
import 'transfer_page.dart';
import 'swap_page.dart';
import 'profile_page.dart';
import 'bank_wallet_screen.dart';

class HomePage extends StatefulWidget {
  const HomePage({Key? key}) : super(key: key);

  @override
  State<HomePage> createState() => _HomePageState();
}

class _HomePageState extends State<HomePage> {
  bool _isBalanceVisible = true;
  final BlockchainService _blockchainService = BlockchainService();
  String? _walletBalance; // Balance from Web3 (in LSK)
  bool _isLoadingBalance = false;

  // ===== Dashboard Home (Figma) asset helpers =====
  static const String _hp = 'assets/icons/Homepage/';
  static const String _imgProfile = 'assets/images/Homepage/240_F_699466075_DaPTBNlNQTOwwjkOiFEoOvzDV0ByXR9E 1.png';

  // Quick actions (match Figma `Dashboard Home`)
  static const String _icTopUp = '${_hp}Frame@2x-8.png';
  static const String _icTransfer = '${_hp}Frame@2x-6.png';
  static const String _icSwap = '${_hp}Frame@2x-13.png';
  static const String _icMerchant = '${_hp}Frame@2x-14.png';
  static const String _icMore = '${_hp}Frame@2x-7.png';

  // Header / misc icons
  static const String _icBell = '${_hp}Frame@2x-15.png';
  static const String _icEyeSmall = '${_hp}Eye@2x.png';
  static const String _icKebab = '${_hp}Frame@2x-10.png';

  // Transaction icons
  static const String _icNetflix = '${_hp}Frame@2x-4.png';
  static const String _icShopee = '${_hp}Frame@2x-5.png';
  static const String _icWarung = '${_hp}Frame@2x-3.png';

  // Bottom nav
  static const String _icNavHome = '${_hp}Frame@2x-11.png';
  static const String _icNavCard = '${_hp}Clip path group@2x.png';
  static const String _icNavSend = '${_hp}Frame@2x-12.png';
  static const String _icNavProfile = '${_hp}Vector@2x.png';
  static const String _icNavQr = '${_hp}Frame@2x-1.png';
  static const String _bgNavQr = '${_hp}Ellipse 14@2x.png';

  @override
  Widget build(BuildContext context) {
    final screenWidth = MediaQuery.of(context).size.width;
    final screenHeight = MediaQuery.of(context).size.height;
    final bottomPadding = MediaQuery.of(context).padding.bottom;

    final s = screenWidth / 393.0;

    return BlocListener<AuthBloc, AuthState>(
      listener: (context, state) {
        if (state is AuthSuccess) {
          _loadBalanceForUser(state.user.walletAddress);
        }
      },
      child: Scaffold(
        body: Stack(
          children: [
          // ====== BACKGROUND DENGAN GPLAY 1-4 PATTERN ======
          _buildBackgroundWithPattern(screenWidth, screenHeight),

          // ====== MAIN CONTENT ======
          SafeArea(
            bottom: false,
            child: SingleChildScrollView(
              physics: const BouncingScrollPhysics(),
              child: SizedBox(
                height: 845 * s,
                width: screenWidth,
                child: _buildDashboardHomeFigma(s),
              ),
            ),
          ),

          // ====== BOTTOM NAVIGATION ======
          Positioned(
            left: 0,
            right: 0,
            bottom: 0,
            child: _buildBottomNavigation(s, screenWidth, bottomPadding),
          ),
        ],
      ),
    );
  }

  @override
  void dispose() {
    _blockchainService.dispose();
    super.dispose();
  }

  Future<void> _loadBalanceForUser(String? walletAddress) async {
    if (walletAddress == null || walletAddress.isEmpty) {
      setState(() {
        _walletBalance = null;
      });
      return;
    }

    if (_isLoadingBalance) return;

    setState(() {
      _isLoadingBalance = true;
    });

    try {
      final balanceLSK = await _blockchainService.getBalanceInLSK(walletAddress);
      if (!mounted) return;
      setState(() {
        _walletBalance = balanceLSK;
      });
    } catch (e) {
      if (!mounted) return;
      setState(() {
        _walletBalance = null;
      });
    } finally {
      if (!mounted) return;
      setState(() {
        _isLoadingBalance = false;
      });
    }
  }

  // ==================== BACKGROUND DENGAN GPLAY PATTERN (SEAMLESS BLEND) ====================
  Widget _buildBackgroundWithPattern(double screenWidth, double screenHeight) {
    return Stack(
      children: [
        // ===== LAYER 1: Base Gradient =====
        Container(
          width: double.infinity,
          height: double.infinity,
          decoration: const BoxDecoration(
            gradient: LinearGradient(
              begin: Alignment.topCenter,
              end: Alignment.bottomCenter,
              stops: [0.0, 0.4, 0.7, 1.0],
              colors: [
                Color(0xFF065758), // Dark teal
                Color(0xFF0A7879), // Mid teal
                Color(0xFF9FC5C5), // Light teal
                Color(0xFFF0F0F0), // Near white
              ],
            ),
          ),
        ),

        // ===== LAYER 2: Full-screen pattern with ColorFilter =====
        // Use full-screen coverage with proper blending
        Positioned.fill(
          child: ColorFiltered(
            colorFilter: ColorFilter.mode(
              const Color(0xFF076162).withOpacity(0.85), // Teal tint
              BlendMode.srcATop,
            ),
            child: Opacity(
              opacity: 0.20, // Subtle pattern visibility
              child: Image.asset(
                'assets/images/Homepage/gplay 1.png',
                width: double.infinity,
                height: double.infinity,
                fit: BoxFit.cover,
                repeat: ImageRepeat.repeat, // Tile the pattern
                errorBuilder: (_, __, ___) => const SizedBox.shrink(),
              ),
            ),
          ),
        ),

        // ===== LAYER 3: Second pattern (rotated feel) =====
        Positioned.fill(
          child: ColorFiltered(
            colorFilter: ColorFilter.mode(
              const Color(0xFF065758).withOpacity(0.75),
              BlendMode.overlay,
            ),
            child: Opacity(
              opacity: 0.12,
              child: Image.asset(
                'assets/images/Homepage/gplay 3.png',
                width: double.infinity,
                height: double.infinity,
                fit: BoxFit.cover,
                errorBuilder: (_, __, ___) => const SizedBox.shrink(),
              ),
            ),
          ),
        ),

        // ===== LAYER 4: Smooth gradient overlay for bottom fade =====
        Positioned.fill(
          child: IgnorePointer(
            child: Container(
              decoration: BoxDecoration(
                gradient: LinearGradient(
                  begin: Alignment.topCenter,
                  end: Alignment.bottomCenter,
                  stops: const [0.0, 0.35, 0.55, 0.75, 1.0],
                  colors: [
                    Colors.transparent,
                    Colors.transparent,
                    const Color(0xFF9FC5C5).withOpacity(0.4),
                    const Color(0xFFD5E5E5).withOpacity(0.7),
                    const Color(0xFFF0F0F0).withOpacity(0.95),
                  ],
                ),
              ),
            ),
          ),
        ),
      ],
    );
  }

  // ==================== DASHBOARD HOME (PIXEL PERFECT - Figma 392:872) ====================
  Widget _buildDashboardHomeFigma(double s) {
    return Stack(
      children: [
        // Header avatar
        Positioned(
          left: 28 * s,
          top: 25 * s,
          child: GestureDetector(
            onTap: () {
              Navigator.push(context, MaterialPageRoute(builder: (_) => const ProfileScreen()));
            },
            child: BlocBuilder<AuthBloc, AuthState>(
              builder: (context, state) {
                String? url;
                if (state is AuthSuccess) {
                  url = state.user.profilePicture;
                }
                return ClipOval(
                  child: (url != null && url.isNotEmpty)
                      ? Image.network(
                          url,
                          width: 44 * s,
                          height: 44 * s,
                          fit: BoxFit.cover,
                          errorBuilder: (_, __, ___) => Image.asset(
                            _imgProfile,
                            width: 44 * s,
                            height: 44 * s,
                            fit: BoxFit.cover,
                          ),
                        )
                      : Image.asset(
                          _imgProfile,
                          width: 44 * s,
                          height: 44 * s,
                          fit: BoxFit.cover,
                        ),
                );
              },
            ),
          ),
        ),

        // Name next to profile (requested)
        Positioned(
          left: 80 * s,
          top: 30 * s,
          width: 200 * s,
          child: BlocBuilder<AuthBloc, AuthState>(
            builder: (context, state) {
              String userName = 'User';
              if (state is AuthSuccess) {
                userName = state.user.name ??
                    state.user.email?.split('@')[0] ??
                    'User';
              }
              return Text(
                userName,
                maxLines: 1,
                overflow: TextOverflow.ellipsis,
                style: GoogleFonts.poppins(
                  color: Colors.white.withOpacity(0.95),
                  fontSize: 14 * s,
                  fontWeight: FontWeight.w500,
                ),
              );
            },
          ),
        ),

        // Wallet ID next to profile (requested)
        Positioned(
          left: 80 * s,
          top: 50 * s,
          width: 240 * s,
          child: BlocBuilder<AuthBloc, AuthState>(
            builder: (context, state) {
              String walletId = '';
              if (state is AuthSuccess) {
                final w = state.user.walletAddress ?? '';
                if (w.isNotEmpty) {
                  walletId = (w.length > 16)
                      ? '${w.substring(0, 10)}...${w.substring(w.length - 6)}'
                      : w;
                }
              }
              return Text(
                walletId.isEmpty ? '' : 'Wallet ID: $walletId',
                maxLines: 1,
                overflow: TextOverflow.ellipsis,
                style: GoogleFonts.poppins(
                  color: Colors.white.withOpacity(0.75),
                  fontSize: 11 * s,
                  fontWeight: FontWeight.w400,
                ),
              );
            },
          ),
        ),

        // (Removed old centered "Welcome!" text to keep header clean)

        // Bell icon right
        Positioned(
          left: 339 * s,
          top: 33 * s,
          child: Image.asset(
            _icBell,
            width: 26 * s,
            height: 26 * s,
            fit: BoxFit.contain,
          ),
        ),

        // Total Balance label + dynamic amount from Web3
        Positioned(
          left: (393 / 2 - 61.5) * s,
          top: 104 * s,
          child: Row(
            children: [
              Text(
                'Total Balance',
                style: GoogleFonts.poppins(
                  color: Colors.white,
                  fontSize: 17 * s,
                  fontWeight: FontWeight.w300,
                ),
              ),
              SizedBox(width: 6 * s),
              GestureDetector(
                onTap: () => setState(() => _isBalanceVisible = !_isBalanceVisible),
                child: Image.asset(
                  _icEyeSmall,
                  width: 16 * s,
                  height: 11 * s,
                  fit: BoxFit.contain,
                ),
              ),
            ],
          ),
        ),
        // Total amount (dynamic)
        Positioned(
          left: (393 / 2 - 118.5) * s,
          top: 126 * s,
          child: Builder(
            builder: (_) {
              String balanceText;
              if (_isBalanceVisible) {
                if (_walletBalance != null) {
                  balanceText = '${_walletBalance} ${Env.liskCurrencySymbol}';
                } else if (_isLoadingBalance) {
                  balanceText = 'Loading...';
                } else {
                  balanceText = '--';
                }
              } else {
                balanceText = '••••••';
              }

              return Text(
                balanceText,
                style: GoogleFonts.poppins(
                  color: Colors.white,
                  fontSize: 32 * s,
                  fontWeight: FontWeight.w600,
                  letterSpacing: -0.5,
                ),
              );
            },
          ),
        ),

        // Wallet panel (My Wallet)
        Positioned(
          left: 34 * s,
          top: 192 * s,
          child: _buildWalletPanelFigma(s),
        ),

        // Quick actions row
        _buildQuickActionsFigma(s),

        // Transaction section
        _buildTransactionSectionFigma(s),
      ],
    );
  }

  Widget _buildWalletPanelFigma(double s) {
    return BlocBuilder<AuthBloc, AuthState>(
      builder: (context, state) {
        String userName = 'User';
        String cardNumberDisplay = '----';
        String cardLastDigits = '----';
        String balanceDisplay = _walletBalance ?? '0.000000';

        if (state is AuthSuccess) {
          userName = state.user.name ??
              state.user.email?.split('@')[0] ??
              'User';

          final addr = state.user.walletAddress ?? '';
          if (addr.isNotEmpty) {
            // Shorten wallet address for display on the card
            if (addr.length > 16) {
              cardNumberDisplay = '${addr.substring(0, 10)}...${addr.substring(addr.length - 6)}';
              cardLastDigits = addr.substring(addr.length - 4);
            } else {
              cardNumberDisplay = addr;
              cardLastDigits = addr;
            }
          }

          if (_walletBalance != null) {
            balanceDisplay = _walletBalance!;
          }
        }
        return WalletCard(
          scale: s,
          userName: userName,
          cardNumber: cardNumberDisplay,
          cardLastDigits: cardLastDigits,
          balance: balanceDisplay,
          maskedBalance: '••••••',
          currency: Env.liskCurrencySymbol,
          eyeIconAsset: _icEyeSmall,
          plusIconAsset: _icTopUp,
          textureAsset: 'assets/images/Homepage/gplay 1.png',
        );
      },
    );
  }

  Widget _buildQuickActionsFigma(double s) {
    Widget item({
      required double left,
      required String label,
      required String icon,
      required bool active,
      required VoidCallback onTap,
    }) {
      return Positioned(
        left: left * s,
        top: 406 * s,
        child: Column(
          children: [
            GestureDetector(
              onTap: onTap,
              child: Container(
                width: 52 * s,
                height: 52 * s,
                decoration: BoxDecoration(
                  color: active ? const Color(0xFF08BFC1) : Colors.black.withOpacity(0.47),
                  borderRadius: BorderRadius.circular(10 * s),
                ),
                child: Center(
                  child: Image.asset(icon, width: 27 * s, height: 27 * s),
                ),
              ),
            ),
            SizedBox(height: 6 * s),
            SizedBox(
              width: 62 * s,
              child: Text(
                label,
                textAlign: TextAlign.center,
                style: GoogleFonts.poppins(
                  color: const Color(0xFF4E4E4E),
                  fontSize: 13 * s,
                  fontWeight: FontWeight.w300,
                ),
              ),
            ),
          ],
        ),
      );
    }

    return Stack(
      children: [
        item(left: 29, label: 'Top Up', icon: _icTopUp, active: true, onTap: () {}),
        item(left: 100, label: 'Transfer', icon: _icTransfer, active: false, onTap: () {
          Navigator.push(context, MaterialPageRoute(builder: (_) => const TransferScreen()));
        }),
        item(left: 171, label: 'Swap', icon: _icSwap, active: false, onTap: () {
          Navigator.push(context, MaterialPageRoute(builder: (_) => const SwapScreen()));
        }),
        item(left: 240, label: 'Merchant', icon: _icMerchant, active: false, onTap: () {}),
        item(left: 308, label: 'More', icon: _icMore, active: false, onTap: () {}),
      ],
    );
  }

