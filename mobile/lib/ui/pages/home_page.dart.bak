  // ==================== BOTTOM NAVIGATION (PERFECTLY CENTERED) ====================
  Widget _buildBottomNavigation(double s, double screenWidth, double bottomPadding) {
    final navHeight = 76 * s;
    final qrButtonSize = 56 * s;

    Future<void> onTapQr() async {
      final result = await Navigator.push(
        context,
        MaterialPageRoute(builder: (_) => const ScanQrisScreen()),
      );

      if (result != null && mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('QR Code scanned successfully', style: GoogleFonts.poppins()),
            backgroundColor: const Color(0xFF08BFC1),
          ),
        );
      }
    }

    return SizedBox(
      width: screenWidth,
      height: navHeight + bottomPadding,
      child: Stack(
        clipBehavior: Clip.none,
        children: [
          // Bar background
          Positioned(
            left: 0,
            right: 0,
            bottom: 0,
            child: Container(
              height: navHeight + bottomPadding,
              decoration: BoxDecoration(
                color: const Color(0xFF1A1A1A),
                boxShadow: [
                  BoxShadow(
                    color: Colors.black.withOpacity(0.3),
                    blurRadius: 10,
                    offset: const Offset(0, -2),
                  ),
                ],
              ),
              padding: EdgeInsets.only(bottom: bottomPadding),
              // Use Row with equal spacing for perfect alignment
              child: Row(
                mainAxisAlignment: MainAxisAlignment.spaceEvenly,
                children: [
                  // Home (position 1)
                  _buildNavIconButton(s: s, asset: _icNavHome, size: 26 * s, onTap: null),
                  // Card (position 2) - Navigate to Bank & Wallet Account
                  _buildNavIconButton(
                    s: s,
                    asset: _icNavCard,
                    size: 24 * s,
                    onTap: () => Navigator.push(
                      context,
                      MaterialPageRoute(builder: (_) => const BankWalletScreen()),
                    ),
                  ),
                  // Center spacer for QR (position 3) - EXACT same width as other items
                  SizedBox(width: 48 * s),
                  // Send (position 4) - Navigate to Transfer
                  _buildNavIconButton(
                    s: s,
                    asset: _icNavSend,
                    size: 24 * s,
                    onTap: () => Navigator.push(
                      context,
                      MaterialPageRoute(builder: (_) => const TransferScreen()),
                    ),
                  ),
                  // Profile (position 5)
                  _buildNavIconButton(
                    s: s,
                    asset: _icNavProfile,
                    size: 22 * s,
                    onTap: () => Navigator.push(context, MaterialPageRoute(builder: (_) => const ProfileScreen())),
                  ),
                ],
              ),
            ),
          ),

          // QR button - EXACTLY CENTERED
          Positioned(
            left: 0,
            right: 0,
            bottom: navHeight + bottomPadding - (qrButtonSize / 2),
            child: Center(
              child: GestureDetector(
                onTap: onTapQr,
                child: Container(
                  width: qrButtonSize,
                  height: qrButtonSize,
                  decoration: BoxDecoration(
                    color: const Color(0xFF1A1A1A),
                    shape: BoxShape.circle,
                    border: Border.all(
                      color: Colors.white.withOpacity(0.2),
                      width: 1.5,
                    ),
                    boxShadow: [
                      BoxShadow(
                        color: Colors.black.withOpacity(0.5),
                        blurRadius: 10,
                        offset: const Offset(0, 3),
                      ),
                    ],
                  ),
                  child: Center(
                    child: ColorFiltered(
                      colorFilter: const ColorFilter.mode(
                        Color(0xFF08BFC1),
                        BlendMode.srcIn,
                      ),
                      child: Image.asset(
                        _icNavQr,
                        width: 26 * s,
                        height: 26 * s,
                      ),
                    ),
                  ),
                ),
              ),
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildNavIconButton({
    required double s,
    required String asset,
    required double size,
    VoidCallback? onTap,
  }) {
    return GestureDetector(
      onTap: onTap,
      behavior: HitTestBehavior.opaque,
      child: Padding(
        padding: EdgeInsets.symmetric(horizontal: 12 * s, vertical: 16 * s),
        child: Image.asset(
          asset,
          width: size,
          height: size,
          errorBuilder: (_, __, ___) => Icon(Icons.error, size: size, color: Colors.grey),
        ),
      ),
    );
  }

  Widget _buildNavItem(double s, IconData icon, bool isActive, VoidCallback? onTap) {
