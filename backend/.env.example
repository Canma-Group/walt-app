# Copy this to .env and fill in your values

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=qris_payments
DB_USER=qris_user
DB_PASSWORD=qris_password_dev

# Server Configuration
PORT=3000

# Escrow master mnemonic for QRIS payments (12-24 words)
# Generate new: https://iancoleman.io/bip39/
# Example from screenshot: ranch bind announce review scatter defy crystal helmet rule powder wasp live note paper setup must company thunder click dry skill this board season
ESCROW_MASTER_MNEMONIC=your twelve word mnemonic phrase here for escrow wallet generation

# Optional: Private keys for contract deployment (if needed)
DEPLOYER_PRIVATE_KEY=0x...your_private_key_here...
HOT_WALLET_PRIVATE_KEY=0x...your_private_key_here...

# Xendit API Key (for QRIS payment simulation)
# Get from: https://dashboard.xendit.co/settings/developers#api-keys
XENDIT_API_KEY=xnd_development_...your_api_key_here...

# QrisEscrowV2 Contract Address (Lisk Sepolia)
QRIS_ESCROW_V2_ADDRESS=0xda7c9CF0988547d6F88899A3a822630bAD52060d

# LSK Token Address (Lisk Sepolia)
LSK_TOKEN_ADDRESS=0x4270A0c8676A10ab8CbE3e92bFd187D94C8f248e

# Lisk Sepolia RPC
LISK_RPC_URL=https://rpc.sepolia-api.lisk.com
LISK_CHAIN_ID=4202
